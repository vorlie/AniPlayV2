{
  "name": "ani-cli-gui",
  "description": "Desktop GUI for ani-cli style anime browsing and playback.",
  "author": "AniPlayV2",
  "repository": {
    "type": "git",
    "url": "https://github.com/vorlie/AniPlayV2.git"
  },
  "private": true,
  "version": "1.12.2",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:ui && electron-builder --win --dir",
    "build:ui": "tsc -b && vite build",
    "pack:dir": "npm run build:ui && electron-builder --win --dir",
    "pack:portable": "npm run build:ui && electron-builder --win portable",
    "pack:linux": "npm run build:ui && electron-builder --linux",
    "build:release": "npm run pack:portable",
    "forge:start": "npm run build:ui && electron-forge start",
    "forge:package": "npm run build:ui && electron-forge package",
    "forge:make": "npm run build:ui && electron-forge make",
    "sync:ciphermap": "node scripts/sync-ciphermap.mjs",
    "test": "vitest run",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "config": {
    "forge": "./forge.config.cjs"
  },
  "build": {
    "appId": "com.aniplayv2.app",
    "productName": "AniPlay",
    "files": [
      "dist/**",
      "dist-electron/**",
      "node_modules/**",
      "!node_modules/ffmpeg-static/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static",
        "to": "bin",
        "filter": [
          "ffmpeg",
          "ffmpeg.exe",
          "ffmpeg.exe.LICENSE",
          "ffmpeg.exe.README",
          "LICENSE"
        ]
      },
      {
        "from": "THIRD_PARTY_NOTICES.md",
        "to": "legal/THIRD_PARTY_NOTICES.md"
      },
      {
        "from": "scripts/launch-safe-graphics.ps1",
        "to": "safe-graphics/launch-safe-graphics.ps1"
      },
      {
        "from": "scripts/launch-safe-graphics.cmd",
        "to": "safe-graphics/launch-safe-graphics.cmd"
      }
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "publish": {
      "provider": "github",
      "owner": "vorlie",
      "repo": "AniPlayV2"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Video"
    }
  },
  "dependencies": {
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@ghostery/adblocker-electron": "^2.18.1",
    "@material/material-color-utilities": "^0.4.0",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.9",
    "encoding": "^0.1.13",
    "ffmpeg-static": "5.3.0",
    "hls.js": "^1.6.16",
    "i18next": "^26.3.6",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.9",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/discord-rpc": "^4.0.11",
    "@types/node": "^24.13.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^3.2.6"
  }
}
